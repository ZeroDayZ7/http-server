# ===============================
# HTTP-Server Configuration
# ===============================

# MySQL container name (Docker)
MYSQL_CONTAINER_NAME=kas-mysql-auth

# MySQL connection details
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=admin
MYSQL_DB=portfolio_db

# Build / binary settings
BIN_DIR=bin
MAIN_DIR=./cmd
BINARY=http-server.exe

# Migrations directory
MIGRATIONS_DIR=database/migrations

# Full DSN used by the application (optional)
# MYSQL_DSN=root:admin@tcp(127.0.0.1:3306)/portfolio_db?parseTime=true
DB_PATH=mysql://${MYSQL_DSN}
