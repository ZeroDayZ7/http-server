# ===============================
# Configuration
# ===============================

# Server
PORT=8080
ENV=development
APP_VERSION=1.0.0

# MySQL
MYSQL_DSN=user:password@tcp(127.0.0.1:3306)/name_db?charset=utf8mb4&parseTime=True&loc=Local

# Database connection pooling
DB_MAX_OPEN_CONNS=50       # Maximum number of open connections
DB_MAX_IDLE_CONNS=10       # Maximum number of idle connections
DB_CONN_MAX_LIFETIME_MIN=30 # Maximum lifetime of a connection in minutes

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_MAX=100          # Max requests per IP
RATE_LIMIT_WINDOW=1m        # Window duration (e.g., 30s, 1m, 1h)

# Request body limit
BODY_LIMIT_MB=2             # Maximum payload size in MB

# Graceful shutdown
SHUTDOWN_TIMEOUT_SEC=5      # Timeout for graceful shutdown in seconds
